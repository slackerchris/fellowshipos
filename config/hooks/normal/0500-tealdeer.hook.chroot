#!/bin/bash
set -e

# Install tealdeer (tldr) from GitHub releases
TEALDEER_VERSION="1.6.1"
curl -fsSL "https://github.com/dbrgn/tealdeer/releases/download/v${TEALDEER_VERSION}/tealdeer-linux-x86_64-musl" \
    -o /usr/local/bin/tldr
chmod +x /usr/local/bin/tldr

# Pre-cache tldr pages
tldr --update || true
