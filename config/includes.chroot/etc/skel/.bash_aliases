# Navigation
alias ll='eza -lah --icons'
alias ls='eza --icons'
alias lt='eza --tree --icons'

# Git
alias gs='git status'
alias gl='git log --oneline --graph --decorate'

# Docker
alias dps='docker ps'
alias dpa='docker ps -a'
alias dlog='docker logs -f'

# Disk
alias df='df -h'
alias du='du -h'

# bat over cat
alias cat='batcat --paging=never'
alias bat='batcat'

# Homelab
alias doom='ssh mountdoom'
